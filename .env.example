# Copy to .env in the repo root for docker compose.
# Never commit .env.

# --- Public site ---
PUBLIC_BASE_URL=http://localhost:8080
HTTP_ADDR=:8080

# CMS admin (optional — leave blank to disable /admin)
ADMIN_USER=
ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=   # optional; derived from ADMIN_PASSWORD when unset

# Blog links
# BLOG_SUBSTACK_URL=https://neonai.substack.com
# BLOG_MEDIUM_URL=https://medium.com/@neonaicloud

# --- Digital twin LLM ---
# Provider: openai | ollama
LLM_PROVIDER=openai

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (when LLM_PROVIDER=ollama)
# From Docker, reach host Ollama via host.docker.internal (macOS/Windows).
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_SUPPORTS_TOOLS=false

# TWIN_DEFAULT_PERSONA=cto

# Optional lead / unknown-question notifications
# PUSHOVER_TOKEN=
# PUSHOVER_USER=
