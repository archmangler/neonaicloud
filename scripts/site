#!/usr/bin/env bash
# Control the Neon AI Cloud site process: start, stop, restart, status.
# Always clears listeners and matching site processes before start.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

BIN_DIR="${BIN_DIR:-$ROOT/bin}"
BIN="$BIN_DIR/neonsite"
PID_FILE="${PID_FILE:-$BIN_DIR/neonsite.pid}"
LOG_FILE="${LOG_FILE:-$BIN_DIR/neonsite.log}"
HTTP_ADDR="${HTTP_ADDR:-:8080}"
HEALTH_PATH="${HEALTH_PATH:-/healthz}"
STOP_WAIT_SECS="${STOP_WAIT_SECS:-5}"
START_WAIT_SECS="${START_WAIT_SECS:-8}"
START_FOREGROUND="${START_FOREGROUND:-0}"

usage() {
  cat <<EOF
Usage: $(basename "$0") <start|stop|restart|status>

Environment:
  HTTP_ADDR          Listen address (default: :8080)
  START_FOREGROUND=1 Run in the foreground (start only)
  BIN_DIR            Build/output directory (default: ./bin)

Examples:
  ./scripts/site start
  ./scripts/site stop
  ./scripts/site restart
  HTTP_ADDR=:3000 ./scripts/site restart
EOF
}

port_from_addr() {
  local addr="$1"
  if [[ "$addr" == *:* ]]; then
    printf '%s\n' "${addr##*:}"
  else
    printf '%s\n' "$addr"
  fi
}

PORT="$(port_from_addr "$HTTP_ADDR")"
if [[ ! "$PORT" =~ ^[0-9]+$ ]]; then
  echo "error: invalid HTTP_ADDR='$HTTP_ADDR' (could not parse port)" >&2
  exit 2
fi

base_url() {
  local host="127.0.0.1"
  if [[ "$HTTP_ADDR" == *:*:* ]]; then
    # host:port form without scheme
    host="${HTTP_ADDR%:*}"
    host="${host#[}"
    host="${host%]}"
  elif [[ "$HTTP_ADDR" != :* && "$HTTP_ADDR" == *:* ]]; then
    host="${HTTP_ADDR%:*}"
  fi
  if [[ -z "$host" || "$host" == "*" || "$host" == "0.0.0.0" ]]; then
    host="127.0.0.1"
  fi
  printf 'http://%s:%s\n' "$host" "$PORT"
}

is_running_pid() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

command_for_pid() {
  ps -p "$1" -o command= 2>/dev/null || true
}

comm_for_pid() {
  # Process name only (never the parent shell command line).
  local comm
  comm="$(ps -p "$1" -o comm= 2>/dev/null || true)"
  comm="${comm##*/}"
  comm="${comm// /}"
  printf '%s\n' "$comm"
}

is_shell_comm() {
  case "$1" in
    zsh | bash | sh | dash | fish | csh | tcsh | ksh) return 0 ;;
    *) return 1 ;;
  esac
}

# True only for site server processes, never control scripts or parent shells.
is_site_pid() {
  local pid="$1"
  local comm cmd
  [[ "$pid" == "$$" ]] && return 1
  is_running_pid "$pid" || return 1

  comm="$(comm_for_pid "$pid")"
  if is_shell_comm "$comm"; then
    return 1
  fi
  if [[ "$comm" == "neonsite" ]]; then
    return 0
  fi

  cmd="$(command_for_pid "$pid")"
  # Reject control scripts and wrappers whose argv merely mentions neonsite.
  if [[ "$cmd" == *"/scripts/site"* || "$cmd" == *" scripts/site"* ]]; then
    return 1
  fi
  if [[ "$cmd" == *"/scripts/start"* || "$cmd" == *"/scripts/stop"* || "$cmd" == *"/scripts/restart"* ]]; then
    return 1
  fi

  # go run temp binary or direct invocation of the built binary.
  if [[ "$cmd" == *"/exe/neonsite"* || "$cmd" == */neonsite || "$cmd" == */neonsite\ * ]]; then
    return 0
  fi
  return 1
}

collect_pids() {
  local -a found=()
  local pid

  if [[ -f "$PID_FILE" ]]; then
    pid="$(tr -d '[:space:]' <"$PID_FILE" || true)"
    if is_site_pid "$pid"; then
      found+=("$pid")
    fi
  fi

  # Anything listening on the configured port must be cleared.
  if command -v lsof >/dev/null 2>&1; then
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      # Only kill listeners that are site binaries (or unknown non-shells on our port).
      if is_site_pid "$pid"; then
        found+=("$pid")
        continue
      fi
      # Non-shell listener on our port still blocks start; clear it.
      if is_running_pid "$pid" && ! is_shell_comm "$(comm_for_pid "$pid")"; then
        found+=("$pid")
      fi
    done < <(lsof -nP -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null || true)
  fi

  # Stray site binaries not necessarily bound yet (or on another interface).
  if command -v pgrep >/dev/null 2>&1; then
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      if is_site_pid "$pid"; then
        found+=("$pid")
      fi
    done < <(pgrep -x neonsite 2>/dev/null || true)
  fi

  # Unique PIDs, stable order.
  if ((${#found[@]} > 0)); then
    printf '%s\n' "${found[@]}" | awk 'NF && !seen[$0]++'
  fi
}

signal_pids() {
  local sig="$1"
  shift
  local pid
  for pid in "$@"; do
    if is_running_pid "$pid"; then
      echo "  send $sig -> pid $pid ($(command_for_pid "$pid"))"
      kill "-$sig" "$pid" 2>/dev/null || true
    fi
  done
}

wait_until_dead() {
  local timeout="$1"
  shift
  local pid
  local deadline=$((SECONDS + timeout))
  while ((SECONDS < deadline)); do
    local alive=0
    for pid in "$@"; do
      if is_running_pid "$pid"; then
        alive=1
        break
      fi
    done
    if ((alive == 0)); then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

port_in_use() {
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$PORT" -sTCP:LISTEN -t >/dev/null 2>&1
    return $?
  fi
  # Fallback: try binding check via go-free approach is unavailable; assume free.
  return 1
}

wait_port_free() {
  local timeout="$1"
  local deadline=$((SECONDS + timeout))
  while ((SECONDS < deadline)); do
    if ! port_in_use; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

stop_site() {
  echo "Stopping Neon AI Cloud site (port $PORT)..."

  local -a pids=()
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    pids+=("$pid")
  done < <(collect_pids)

  if ((${#pids[@]} == 0)); then
    echo "No site processes found."
    rm -f "$PID_FILE"
    if port_in_use; then
      echo "error: port $PORT is still in use by a non-site process:" >&2
      lsof -nP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true
      return 1
    fi
    echo "Port $PORT is free."
    return 0
  fi

  echo "Found process(es): ${pids[*]}"
  signal_pids TERM "${pids[@]}"

  if ! wait_until_dead "$STOP_WAIT_SECS" "${pids[@]}"; then
    echo "Graceful stop timed out; forcing kill..."
    signal_pids KILL "${pids[@]}"
    wait_until_dead 2 "${pids[@]}" || true
  fi

  # Second sweep for anything that re-bound or was missed.
  local -a remaining=()
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    remaining+=("$pid")
  done < <(collect_pids)

  if ((${#remaining[@]} > 0)); then
    echo "Clearing remaining process(es): ${remaining[*]}"
    signal_pids KILL "${remaining[@]}"
    wait_until_dead 2 "${remaining[@]}" || true
  fi

  rm -f "$PID_FILE"

  if ! wait_port_free 3; then
    echo "error: port $PORT is still in use after stop:" >&2
    lsof -nP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true
    return 1
  fi

  echo "Stopped. Port $PORT is free."
}

build_site() {
  mkdir -p "$BIN_DIR"
  echo "Building $BIN ..."
  go build -trimpath -o "$BIN" ./cmd/neonsite
}

wait_healthy() {
  local url
  url="$(base_url)$HEALTH_PATH"
  local deadline=$((SECONDS + START_WAIT_SECS))
  while ((SECONDS < deadline)); do
    if curl -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

start_site() {
  # Always clear first so start never stacks listeners or stale embeds.
  stop_site

  if ! command -v go >/dev/null 2>&1; then
    echo "error: go is not on PATH" >&2
    exit 1
  fi

  build_site

  if port_in_use; then
    echo "error: port $PORT became busy before start" >&2
    lsof -nP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true
    exit 1
  fi

  mkdir -p "$BIN_DIR"
  : >"$LOG_FILE"

  echo "Starting $BIN (HTTP_ADDR=$HTTP_ADDR)..."

  if [[ "$START_FOREGROUND" == "1" ]]; then
    export HTTP_ADDR
    echo $$ >"$PID_FILE"
    exec env HTTP_ADDR="$HTTP_ADDR" "$BIN"
  fi

  env HTTP_ADDR="$HTTP_ADDR" "$BIN" >>"$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" >"$PID_FILE"

  # Confirm the child is still alive and owns the port.
  sleep 0.2
  if ! is_running_pid "$pid"; then
    echo "error: site process exited immediately; log:" >&2
    cat "$LOG_FILE" >&2 || true
    rm -f "$PID_FILE"
    exit 1
  fi

  if ! wait_healthy; then
    echo "error: site did not become healthy at $(base_url)$HEALTH_PATH" >&2
    echo "--- log ---" >&2
    cat "$LOG_FILE" >&2 || true
    stop_site || true
    exit 1
  fi

  echo "Started pid $pid"
  echo "URL:     $(base_url)/"
  echo "Health:  $(base_url)$HEALTH_PATH"
  echo "Log:     $LOG_FILE"
  echo "PID file:$PID_FILE"
}

status_site() {
  local -a pids=()
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    pids+=("$pid")
  done < <(collect_pids)

  echo "HTTP_ADDR=$HTTP_ADDR (port $PORT)"
  if ((${#pids[@]} == 0)); then
    echo "Status: stopped"
    if port_in_use; then
      echo "Warning: port $PORT is in use by another process:"
      lsof -nP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true
      return 1
    fi
    return 0
  fi

  echo "Status: running"
  local pid
  for pid in "${pids[@]}"; do
    echo "  pid $pid  $(command_for_pid "$pid")"
  done

  if curl -fsS "$(base_url)$HEALTH_PATH" >/dev/null 2>&1; then
    echo "Health: ok ($(base_url)$HEALTH_PATH)"
  else
    echo "Health: not responding ($(base_url)$HEALTH_PATH)"
    return 1
  fi
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    start) start_site ;;
    stop) stop_site ;;
    restart)
      # start_site always stops and clears first.
      start_site
      ;;
    status) status_site ;;
    -h | --help | help) usage ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
