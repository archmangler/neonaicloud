# Copy to agentic/.env and fill in locally. Never commit agentic/.env.
#
# The key stays on the server: Gradio runs app.py, which calls OpenAI.
# The browser chat UI never receives or sends the API key.

OPENAI_API_KEY=

# Optional
# OPENAI_MODEL=gpt-4o-mini
# PERSONA=cto
# PUSHOVER_TOKEN=
# PUSHOVER_USER=
# TWIN_HTTP_HOST=127.0.0.1
# TWIN_HTTP_PORT=7861

# Go site proxy (set when running neonsite alongside the twin API)
# TWIN_SERVICE_URL=http://127.0.0.1:7861
# TWIN_DEFAULT_PERSONA=cto
