# Copy to agentic/.env and fill in locally. Never commit agentic/.env.
#
# Credentials stay on the server — never sent to the browser chat UI.

# --- LLM provider: openai | ollama ---
LLM_PROVIDER=openai

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=ollama
# OLLAMA_SUPPORTS_TOOLS=false

# Optional
# PERSONA=cto
# PUSHOVER_TOKEN=
# PUSHOVER_USER=
# TWIN_HTTP_HOST=127.0.0.1
# TWIN_HTTP_PORT=7861

# Go site proxy (set when running neonsite alongside the twin API)
# TWIN_SERVICE_URL=http://127.0.0.1:7861
# TWIN_DEFAULT_PERSONA=cto
